# Axiom - AI-Powered Penetration Testing Suite
# Environment Variables Configuration

# Required: OpenRouter API key (get one for free at https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: OpenRouter API base URL
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Default LLM model to use
# DEFAULT_MODEL=openrouter/openai/gpt-oss-120b:free

# Optional: Tool timeouts in seconds
# NMAP_TIMEOUT=120
# GENERAL_TOOL_TIMEOUT=60

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO
